{
  "firestore": {
    "database": "(default)",
    "location": "southamerica-east1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "functions": [
    {
      "source": "functions",
      "runtime": "python312", 
      "codebase": "default",
      "ignore": [
        "venv",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ],
      "entryPoint": "telegram_webhook" 
    } 
  ],
  "emulators": {
    "functions": { "port": 5001 },
    "firestore": { "port": 8080 }
  }
}
